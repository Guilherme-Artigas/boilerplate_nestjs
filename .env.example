# Environment variables example file
# Copy this file to .env and modify the values as needed

# Prisma database connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/products_db?schema=public"

# CORS configuration (comma-separated list of allowed origins)
# Use * for allowing all origins or specify domains separated by commas
CORS_ORIGINS="http://localhost:3000,http://localhost:5173/,http://localhost:4200,https://example.com"

# Application port
PORT=3000
